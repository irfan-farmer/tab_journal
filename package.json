{
  "name": "tab_journal",
  "version": "1.1.0",
  "description": "Cross-browser extension that snapshots open tabs into a searchable, exportable, fully-local journal so links are never lost.",
  "type": "module",
  "main": "background.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "node tests/parse_js.cjs && node --test tests/privacy.test.js",
    "icons": "node scripts/make-icons.cjs",
    "build": "node scripts/build.cjs"
  },
  "keywords": [
    "chrome-extension",
    "tabs",
    "history",
    "productivity"
  ],
  "author": "irfan-farmer",
  "license": "MIT",
  "devDependencies": {
    "acorn": "^8.17.0"
  }
}
